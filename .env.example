# TravelHub 2.0 - Configuration Template

# --- Django Core ---
SECRET_KEY=your-secret-key-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# --- Database ---
# Use PostgreSQL in production
DATABASE_URL=postgres://user:password@localhost:5432/travelhub
# Local fallback: DB_NAME=TravelHub ...

# --- Redis (Broker for Celery & Cache) ---
REDIS_URL=redis://localhost:6379/0

# --- AI & GDS Parsing ---
GEMINI_API_KEY=your-google-gemini-api-key
GOOGLE_API_KEY=your-google-cloud-api-key
GCP_PROJECT_ID=travelhub-xxxxxx
GCP_LOCATION=us
GCP_PROCESSOR_ID=your-doc-ai-processor-id
# Path to service account JSON if needed
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# --- Cloudinary (Media Storage) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Email (SMTP & IMAP) ---
# For sending emails (Notifications/Invoices)
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_PORT=587
EMAIL_USE_TLS=True

# For reading tickets (Email Monitor)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
GMAIL_FROM_KIU=noreply@kiusys.com

# --- Stripe (SaaS Billing) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_BASIC=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# --- Telegram (Notifications & Storage) ---
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_ID=your-user-id
TELEGRAM_GROUP_ID=your-group-id
TELEGRAM_STORAGE_CHANNEL_ID=-100xxxxxxxx

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your-token
TWILIO_WHATSAPP_NUMBER=+14155238886
ADMIN_WHATSAPP_NUMBER=+584126080861

# --- Marketing & Design ---
UNSPLASH_ACCESS_KEY=your-unsplash-key

# --- Monitoring ---
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# --- Environment ---
ENVIRONMENT=production
